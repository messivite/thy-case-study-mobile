{
  "name": "thy-case-study-mobile",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:android",
    "ios": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios",
    "ios:xcode": "open ./ios/THYAsistan.xcworkspace",
    "log:ios": "xcrun simctl spawn booted log stream --level debug --style compact --predicate 'process == \"THYAsistan\" OR eventMessage CONTAINS[c] \"RCTFatal\" OR eventMessage CONTAINS[c] \"SIGABRT\" OR eventMessage CONTAINS[c] \"uncaught\" OR eventMessage CONTAINS[c] \"NativeModule\" OR eventMessage CONTAINS[c] \"terminating app\"'",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "test": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "typecheck": "tsc --noEmit",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
