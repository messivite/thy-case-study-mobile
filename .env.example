EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=
# Sentry → Project Settings → Client Keys (DSN). app.json plugin: org messivite, project thy-case-study-assistant
EXPO_PUBLIC_SENTRY_DSN=

# Build-time upload (source maps / symbols). sentry.io → User Settings → Auth Tokens — asla commit etme.
# SENTRY_AUTH_TOKEN=

# Token/org hazır değilken build kırılmasın. Upload açmak için satırı sil veya false + token ekle.
SENTRY_DISABLE_AUTO_UPLOAD=true
